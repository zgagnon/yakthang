// Biscotty theme for Zellij — light variant matching Ghostty biscotty
// Warm peachy-cream background (#f5ede5) with restrained strategic highlighting.
//
// The key value is text_unselected.background = 245 237 229 (#f5ede5).
// yak-map reads this via ModeUpdate to detect light mode and switch to the
// LIGHT ColorScheme (WCAG AA contrast against #f5ede5).

themes {
    biscotty {
        text_unselected {
            base 58 58 58           // #3a3a3a foreground
            background 245 237 229  // #f5ede5 background — used for light mode detection
            emphasis_0 209 72 48    // #d14830 red
            emphasis_1 0 135 95     // #00875f green
            emphasis_2 215 135 95   // #d7875f warm orange
            emphasis_3 122 74 148   // #7a4a94 magenta
        }
        text_selected {
            base 58 58 58
            background 229 217 204  // #e5d9cc selection background
            emphasis_0 209 72 48
            emphasis_1 0 135 95
            emphasis_2 215 135 95
            emphasis_3 122 74 148
        }
        ribbon_selected {
            base 245 237 229        // light text on colored tab
            background 82 118 161   // #5276a1 cursor blue
            emphasis_0 209 72 48
            emphasis_1 215 135 95
            emphasis_2 122 74 148
            emphasis_3 0 135 95
        }
        ribbon_unselected {
            base 58 58 58
            background 215 135 95   // #d7875f warm orange
            emphasis_0 209 72 48
            emphasis_1 245 237 229
            emphasis_2 0 135 95
            emphasis_3 122 74 148
        }
        table_title {
            base 82 118 161         // #5276a1 blue accent
            background 0
            emphasis_0 209 72 48
            emphasis_1 0 135 95
            emphasis_2 215 135 95
            emphasis_3 122 74 148
        }
        table_cell_selected {
            base 58 58 58
            background 229 217 204
            emphasis_0 209 72 48
            emphasis_1 0 135 95
            emphasis_2 215 135 95
            emphasis_3 122 74 148
        }
        table_cell_unselected {
            base 58 58 58
            background 245 237 229
            emphasis_0 209 72 48
            emphasis_1 0 135 95
            emphasis_2 215 135 95
            emphasis_3 122 74 148
        }
        list_selected {
            base 58 58 58
            background 229 217 204
            emphasis_0 209 72 48
            emphasis_1 0 135 95
            emphasis_2 215 135 95
            emphasis_3 122 74 148
        }
        list_unselected {
            base 58 58 58
            background 245 237 229
            emphasis_0 209 72 48
            emphasis_1 0 135 95
            emphasis_2 215 135 95
            emphasis_3 122 74 148
        }
        frame_unselected {
            base 138 138 138        // #8a8a8a dim gray
            background 0
            emphasis_0 209 72 48
            emphasis_1 0 135 95
            emphasis_2 122 74 148
            emphasis_3 0
        }
        frame_selected {
            base 82 118 161         // #5276a1 cursor blue for focused pane
            background 0
            emphasis_0 209 72 48
            emphasis_1 0 135 95
            emphasis_2 122 74 148
            emphasis_3 0
        }
        frame_highlight {
            base 209 72 48          // #d14830 red for mode highlights
            background 0
            emphasis_0 122 74 148
            emphasis_1 209 72 48
            emphasis_2 209 72 48
            emphasis_3 209 72 48
        }
        exit_code_success {
            base 0 135 95           // #00875f green
            background 0
            emphasis_0 0 135 95
            emphasis_1 58 58 58
            emphasis_2 122 74 148
            emphasis_3 0 135 95
        }
        exit_code_error {
            base 209 72 48          // #d14830 red
            background 0
            emphasis_0 215 135 95
            emphasis_1 0
            emphasis_2 0
            emphasis_3 0
        }
        multiplayer_user_colors {
            player_1 122 74 148     // magenta
            player_2 0 135 95       // green
            player_3 0
            player_4 215 135 95     // orange
            player_5 0 135 95       // green
            player_6 0
            player_7 209 72 48      // red
            player_8 0
            player_9 0
            player_10 0
        }
    }
}
