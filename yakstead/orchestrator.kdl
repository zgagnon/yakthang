theme "biscotty"

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="status-bar"
        }
    }

    // --- Orchestrator tab ---------------------------------------------------
    tab name="Yakob's 🛖" focus=true {
        pane split_direction="vertical" {
            // Left 1/3: live yak status with assignments (Zellij plugin)
            pane size="45%" name="yak-map" {
                plugin location="file:~/.local/share/zellij/plugins/yak-map.wasm" {
                    light_mode "true"
                }
            }

            // Right 2/3: Claude (Yakob) + shell
            pane split_direction="horizontal" size="67%" {
                pane name="yakob" focus=true {
                    command "claude"
                    args "--agent" "yakob" "--dangerously-skip-permissions"
                }
                pane size="20%" name="shell (orchestrator)"
            }
        }
    }

    // --- Worker tabs are created dynamically by spawn-worker.sh -------------
    // The orchestrator calls:
    //   spawn-worker.sh --cwd ./api --name "auth-worker" \
    //     "You have access to yx. Run 'yx ls' to see tasks. ..."
    //
    // Each worker gets its own tab via yak-box spawn.
}
